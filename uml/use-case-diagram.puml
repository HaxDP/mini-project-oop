@startuml
left to right direction

actor "Адміністратор" as Admin
actor "Касир" as Cashier

rectangle "CinemaOOP" {
  usecase "Додати фільм" as UC1
  usecase "Додати зал" as UC2
  usecase "Створити сеанс" as UC3
  usecase "Забронювати місце" as UC4
  usecase "Викупити бронювання" as UC5
  usecase "Скасувати бронювання" as UC6
  usecase "Переглянути аналітику" as UC7
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Cashier --> UC4
Cashier --> UC5
Cashier --> UC6
Admin --> UC7

UC5 .> UC4 : <<include>>
@enduml