@startuml
actor "Касир" as User
participant "ConsoleApp" as UI
participant "CinemaService" as App
participant "ISessionRepository" as Sessions
participant "IReservationRepository" as Reservations

User -> UI: Забронювати місце
UI -> App: reserveSeat(sessionId, row, number, customer)
App -> Sessions: findById(sessionId)
Sessions --> App: session

alt Місце недоступне або невалідне
  App --> UI: Result.Failure("Помилка")
  UI --> User: Показати помилку
else Успіх
  App -> Sessions: upsert(updatedSession)
  App -> Reservations: upsert(newReservation)
  App --> UI: Result.Success(reservation)
  UI --> User: Показати ID бронювання
end
@enduml